# Backend host binding
HOST=127.0.0.1

# Dynamic backend port resolution
# Priority:
# 1) BACKEND_PORT
# 2) PORT
# 3) default 8001
BACKEND_PORT=8001
# PORT=

# Preferred explicit client URL.
# If omitted, clients should construct it from BACKEND_PORT / PORT.
BACKEND_URL=http://127.0.0.1:8001

# Frontend public URL example
FRONTEND_BASE_URL=http://localhost:3000

# Language examples
UI_LANGUAGE=en
CONTENT_LANGUAGE=zh
